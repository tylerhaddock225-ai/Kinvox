NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_ACCOUNT_TOKEN=
POSTMARK_INBOUND_SECRET=
NEXT_PUBLIC_APP_URL=http://app.localhost:3000

# ─── Stripe — billing / credit top-ups ──────────────────────────────────────
# Server-only. Never expose STRIPE_SECRET_KEY to the browser.
#
# Where to find each value in the Stripe Dashboard:
#   STRIPE_SECRET_KEY      → Developers → API keys → "Secret key" (sk_test_... in test mode)
#   STRIPE_WEBHOOK_SECRET  → Developers → Webhooks → <your endpoint> → "Signing secret" (whsec_...)
#   STRIPE_PRICE_*         → Products  → <product>  → Pricing → copy the price id (price_...)
#
# Leave any STRIPE_PRICE_* unset to hide that bundle from the /billing page.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
