# ── SSL / DNS ────────────────────────────────────────────────
# Let's Encrypt contact email for ACME renewal notices.
SSL_EMAIL=

# Split so Traefik builds routes as ${SUBDOMAIN}.${DOMAIN_NAME}.
DOMAIN_NAME=kinvoxtech.com
SUBDOMAIN=sandbox-n8n

# IANA tz name (e.g. America/Chicago).
GENERIC_TIMEZONE=America/Chicago

# ── n8n ──────────────────────────────────────────────────────
# Generate on the VPS:  openssl rand -hex 32
# Losing this value bricks every stored credential — back it up outside git
# (password manager / 1Password). Never commit the populated .env.
N8N_ENCRYPTION_KEY=
